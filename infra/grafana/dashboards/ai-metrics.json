{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "AI Stack observability — 5 panels",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Tokens/sec per model",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(ai_stack_tokens_total[5m])",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "title": "Eval pass rate over time",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "ai_stack_eval_pass_rate_sum / ai_stack_eval_pass_rate_count",
          "legendFormat": "pass rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request rate per endpoint",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(ai_stack_requests_total[5m])",
          "legendFormat": "{{endpoint}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Inference latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(ai_stack_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ai_stack_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ai_stack_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost per 1K requests (local=0, cloud=computed)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "0 * ai_stack_requests_total",
          "legendFormat": "local cost (USD)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "mappings": [{ "type": "value", "options": { "0": { "text": "$0.00 (local)" } } }]
        }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["ai-stack", "llm", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Stack — LLM Observability",
  "uid": "ai-stack-v1",
  "version": 1
}